<?xml version="1.0" encoding="utf-8"?>
<Model name="MetaSqlDeploy">
  <EntityList>
    <Entity name="DeployConfiguration">
      <PropertyList>
        <Property name="RootMode" isRequired="false" />
        <Property name="MigrationRoot" isRequired="false" />
      </PropertyList>
    </Entity>
    <Entity name="DeployTarget">
      <PropertyList>
        <Property name="Name" />
        <Property name="DesiredSql" />
        <Property name="TraitsFile" isRequired="false" />
        <Property name="ConnectionString" isRequired="false" />
        <Property name="ConnectionStringEnvVar" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="DeployConfiguration" />
      </RelationshipList>
    </Entity>
  </EntityList>
</Model>
