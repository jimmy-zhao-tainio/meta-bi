<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>meta-datavault-business</AssemblyName>
  </PropertyGroup>

  <PropertyGroup>
    <UpdateMetaDataVaultBusinessPublishDir Condition="'$(UpdateMetaDataVaultBusinessPublishDir)' == ''">true</UpdateMetaDataVaultBusinessPublishDir>
    <RepoMetaDataVaultBusinessPublishDir>$(MSBuildThisFileDirectory)bin\publish\win-x64\</RepoMetaDataVaultBusinessPublishDir>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Meta.Core" Version="$(MetaFoundationPackageVersion)" />
    <ProjectReference Include="..\..\Core\MetaDataVault.Core.csproj" />
  </ItemGroup>

  <Target
    Name="PublishMetaDataVaultBusinessAfterBuild"
    AfterTargets="Build"
    Condition="'$(OS)' == 'Windows_NT' and '$(UpdateMetaDataVaultBusinessPublishDir)' == 'true' and '$(DesignTimeBuild)' != 'true'">
    <Message Importance="High" Text="Publishing meta-datavault-business.exe to $(RepoMetaDataVaultBusinessPublishDir)" />
    <Exec
      Command="dotnet publish &quot;$(MSBuildProjectFullPath)&quot; --configuration $(Configuration) -r win-x64 --self-contained true -p:PublishSingleFile=true -p:IncludeNativeLibrariesForSelfExtract=true -p:UpdateMetaDataVaultBusinessPublishDir=false -o &quot;$(RepoMetaDataVaultBusinessPublishDir)&quot;" />
  </Target>

</Project>

